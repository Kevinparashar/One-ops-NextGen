{
  "description": "UC-8 approval matrix — the deterministic decision table the gate evaluates at request creation. Rows are tried top-down by priority (lowest first); the FIRST whose `match` is a subset of the request's attributes (catalog_item_id / category / owner_group) wins. `required:false` = self-service (fulfil immediately). The final `match:{}` row is the guaranteed fail-safe catch-all (routes unknowns to the service desk, never auto-approves). This logical matrix is loaded per-tenant by load_approval_policy.py into itsm.approval_policy. Add a row to change routing — no code, no item edit. Resolver semantics: docs/design/uc08-approval-workflow.md §2.e.",
  "policies": [
    { "policy_id": "selfservice_password", "priority": 10, "match": {   "catalog_item_id": "CAT_SE_PASSWORD" }, "required": false, "stages": [], "description": "Password reset — self-service, no approval" },
    { "policy_id": "selfservice_mfa", "priority": 11, "match": {   "catalog_item_id": "CAT_SE_MFA" }, "required": false, "stages": [], "description": "MFA enroll/reset — self-service, no approval" },
    { "policy_id": "triage_incident", "priority": 15, "match": {   "category": "incident" }, "required": false, "stages": [], "description": "Incident/general request — triage, not a catalog approval" },
