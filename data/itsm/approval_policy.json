    { "policy_id": "cat_platform", "priority": 34, "match": {   "category": "platform" }, "required": true, "stages": [   {     "name": "Owning-team approval",     "approver": {       "type": "owning_group"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "catalog_owner"   } ], "description": "Platform → owning platform team" },
