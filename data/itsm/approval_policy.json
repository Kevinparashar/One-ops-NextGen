    { "policy_id": "cat_change", "priority": 37, "match": {   "category": "change" }, "required": true, "stages": [   {     "name": "Owning-team approval",     "approver": {       "type": "owning_group"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "catalog_owner"   } ], "description": "Change request → owning/CAB team" },
    { "policy_id": "fallback_service_desk", "priority": 999, "match": {}, "required": true, "stages": [   {     "name": "Service-desk approval",     "approver": {       "type": "service_desk",       "group": "GRP-SERVICE-DESK"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "catalog_owner"   } ], "description": "FAIL-SAFE catch-all — any request not matched above routes to the service desk for approval (never auto-approves). The service-desk group is declared here as DATA (read by the evaluator's fail-safe), not hardcoded in code." }
  ]
}
