    { "policy_id": "cat_hr", "priority": 21, "match": {   "category": "hr" }, "required": true, "stages": [   {     "name": "Manager approval",     "approver": {       "type": "manager_of_requester"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "manager"   } ], "description": "HR request → line manager" },
    { "policy_id": "cat_hardware", "priority": 22, "match": {   "category": "hardware" }, "required": true, "stages": [   {     "name": "Manager approval",     "approver": {       "type": "manager_of_requester"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "manager"   } ], "description": "Hardware → line manager (budget)" },
    { "policy_id": "cat_telecom", "priority": 23, "match": {   "category": "telecom" }, "required": true, "stages": [   {     "name": "Manager approval",     "approver": {       "type": "manager_of_requester"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "manager"   } ], "description": "Telecom/mobile → line manager (recurring cost)" },
    { "policy_id": "cat_onboarding", "priority": 24, "match": {   "category": "onboarding" }, "required": true, "stages": [   {     "name": "Manager approval",     "approver": {       "type": "manager_of_requester"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "manager"   } ], "description": "Onboarding/offboarding → line manager (HR co-approval is Phase 2 multi-stage)" },
    { "policy_id": "cat_access", "priority": 30, "match": {   "category": "access" }, "required": true, "stages": [   {     "name": "Owning-team approval",     "approver": {       "type": "owning_group"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "catalog_owner"   } ], "description": "Access → the team that owns the resource" },
    { "policy_id": "cat_software", "priority": 31, "match": {   "category": "software" }, "required": true, "stages": [   {     "name": "Owning-team approval",     "approver": {       "type": "owning_group"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "catalog_owner"   } ], "description": "Software/license → owning app team" },
    { "policy_id": "cat_email", "priority": 32, "match": {   "category": "email" }, "required": true, "stages": [   {     "name": "Owning-team approval",     "approver": {       "type": "owning_group"     },     "rule": "any_one",     "block_self_approval": true,     "approval_type": "catalog_owner"   } ], "description": "Email/mailbox → owning messaging team" },
