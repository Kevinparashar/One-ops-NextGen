  {
    "tenant_id": "T001",
    "template_id": "ONB_DEV_SR",
    "name": "Senior Developer onboarding",
    "description": "Standard onboarding template for senior developers joining engineering.",
    "department": "Engineering",
    "default_catalog_item_id": "CAT_ONBOARDING",
    "required_inputs": [
      "employee_name",
      "start_date",
      "manager_user_id",
      "location"
    ],
    "tasks": [
      {
        "task_id": "T1",
        "name": "Create AD account",
        "type": "automated",
        "owner_group": "GRP-SECOPS",
