        "owner_group": "GRP-PLATFORM",
        "depends_on": [
          "T1"
        ],
        "estimated_minutes": 5,
        "automation_endpoint": "internal://github/invite"
      },
      {
        "task_id": "T6",
        "name": "License: IDE + Jira",
        "type": "automated",
        "owner_group": "GRP-PLATFORM",
        "depends_on": [
          "T1"
        ],
        "estimated_minutes": 5,
        "automation_endpoint": "internal://licenses/assign_dev_bundle"
      },
      {
        "task_id": "T7",
        "name": "Create badge request",
        "type": "manual",
        "owner_group": "GRP-SECOPS",
        "depends_on": [
          "T1",
          "T2",
          "T3"
        ],
        "estimated_minutes": 240,
        "manual_form": "badge_request_form_v2"
      },
      {
        "task_id": "T8",
        "name": "Assign desk and workspace",
        "type": "manual",
        "owner_group": "GRP-ASSET",
        "depends_on": [
          "T1",
          "T2",
          "T3"
        ],
        "estimated_minutes": 60,
        "manual_form": "workspace_assignment_v1"
      },
      {
        "task_id": "T9",
        "name": "Send welcome kit email",
        "type": "automated",
        "owner_group": "GRP-SERVICE-DESK",
        "depends_on": [
          "T7",
          "T8"
        ],
        "estimated_minutes": 5,
        "automation_endpoint": "internal://comms/welcome_email"
      }
    ]
  },
