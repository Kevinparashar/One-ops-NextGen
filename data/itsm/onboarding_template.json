        "estimated_minutes": 5,
        "automation_endpoint": "internal://identity/create_account"
      },
      {
        "task_id": "T2",
        "name": "Create email and calendar",
        "type": "automated",
        "owner_group": "GRP-APPS",
        "depends_on": [],
        "estimated_minutes": 10,
        "automation_endpoint": "internal://exchange/provision_mailbox"
      },
      {
        "task_id": "T3",
        "name": "Order laptop",
        "type": "manual",
        "owner_group": "GRP-ASSET",
        "depends_on": [],
        "estimated_minutes": 720,
        "manual_form": "asset_request_form_v3"
      },
      {
        "task_id": "T4",
        "name": "Provision VPN access",
        "type": "automated",
        "owner_group": "GRP-NETOPS",
        "depends_on": [
          "T1"
        ],
        "estimated_minutes": 5,
        "automation_endpoint": "internal://vpn/assign_user"
      },
      {
        "task_id": "T5",
        "name": "Add to GitHub org",
