# OneOps AI Engine — environment template
# Copy to .env and fill in secrets locally. .env is gitignored — never commit it.
# Production: secrets come from AWS Secrets Manager / Vault, NOT this file.

# ── Service identity ─────────────────────────────────────────────────────
SERVICE_NAME=oneops
SERVICE_VERSION=0.2.0
ENVIRONMENT=local                          # local | dev | staging | prod

# ── Registry (P1 — declarative agent/tool/schema store) ──────────────────
REGISTRY_ROOT=registries/v2

# ── LLM Gateway (single egress for every model call) ─────────────────────
LLM_GATEWAY_URL=http://localhost:4000
LLM_GATEWAY_API_KEY=                       # LiteLLM master key
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_PLANNER_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
OPENAI_API_KEY=                            # provider key — used by the gateway

# ── NATS (ADR-0005 — core for routing, JetStream for durable work) ───────
NATS_URL=nats://localhost:4222
# Subjects are computed at runtime: oneops.<tenant>.uc.<agent>.<op>
NATS_SUBJECT_PREFIX=oneops
NATS_REQUEST_TIMEOUT_SECONDS=120
NATS_QUEUE_GROUP=oneops

# ── Dragonfly (session hot cache · rate-limit counters · idempotency) ────
DRAGONFLY_URL=redis://localhost:6379/0
DRAGONFLY_POOL_MAX=50
CACHE_DEFAULT_TTL_SECONDS=300

# ── Session + conversation store (P3) ────────────────────────────────────
SESSION_HOT_WINDOW_EVENTS=40               # events held in the Dragonfly hot window
SESSION_COLD_RETENTION_DAYS=90             # cold-log retention (policy-driven default)

# ── Postgres — tenant/application data ───────────────────────────────────
POSTGRES_URL=postgresql://oneops:oneops@localhost:5432/oneops
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# ── LangGraph checkpoint store (ADR-0004 — DEDICATED database) ───────────
# MUST be a separate database from POSTGRES_URL. The checkpointer runs schema
# DDL (setup()); pointing it at the application database risks the recorded
# 2026-05-16 data-loss incident. Leave CHECKPOINTER=memory until the dedicated
# database is provisioned.
LANGGRAPH_CHECKPOINTER=memory              # memory | postgres
LANGGRAPH_POSTGRES_URL=                    # dedicated checkpoint DB DSN
# AES key for checkpoint encryption (PII in graph state).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
LANGGRAPH_AES_KEY=

# ── OpenTelemetry (the only observability layer) ─────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=oneops
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0                # 100% in dev; lower in prod
OTEL_CAPTURE_TEXT=false                    # true = raw text in spans (debug only)

# ── AuthZ (P4 — service-to-service identity) ─────────────────────────────
# HS256 secret for internal service JWTs. >= 32 bytes. No default — mint/verify
# fails loud without it. Production: from the secret manager.
AUTHZ_JWT_SECRET=

# ── Deployment mode ──────────────────────────────────────────────────────
UC_INVOKER_MODE=local                      # local (in-process) | nats (microservice)
