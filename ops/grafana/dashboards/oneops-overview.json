          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active connections",
      "id": 51,
      "description": "Currently connected NATS clients (agents + workers).",
      "gridPos": {
        "x": 6,
        "y": 45,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "gnatsd_varz_connections"
        }
      ],
      "options": {
        "reduceOptions": {
