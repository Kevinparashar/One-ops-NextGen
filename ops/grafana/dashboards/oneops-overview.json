    {
      "type": "stat",
      "title": "Slow consumers",
      "id": 53,
      "description": "Subscribers that fell behind. Any nonzero value indicates back-pressure \u2014 healthy operation should hold this at zero.",
      "gridPos": {
        "x": 18,
        "y": 45,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "gnatsd_varz_slow_consumers"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
