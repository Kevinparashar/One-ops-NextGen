          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "NATS messages per second (in vs out, live)",
      "id": 54,
      "description": "Server-wide publish (in) versus deliver (out). Out > in is normal \u2014 each published message fans out to all subscribers.",
      "gridPos": {
        "x": 0,
        "y": 51,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "rate(gnatsd_varz_in_msgs[1m])",
          "refId": "A",
