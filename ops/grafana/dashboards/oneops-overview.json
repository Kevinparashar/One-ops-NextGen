{
  "title": "OneOps \u2014 Service Overview",
  "uid": "oneops-overview",
  "schemaVersion": 38,
  "tags": [
    "oneops",
    "slo"
  ],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Turns / minute (live)",
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum(rate(ai_agent_runs_total[5m])) * 60"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Active agents",
      "id": 2,
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "count(count by (agent_id) (ai_agent_runs_total))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cumulative LLM cost ($)",
      "id": 3,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum(ai_llm_cost_usd_micros_total) / 1e6"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "type": "stat",
      "title": "Turn success ratio (all-time)",
      "id": 4,
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum(ai_agent_runs_total{status=\"success\"}) / clamp_min(sum(ai_agent_runs_total{status=~\"success|failed\"}), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Per-UC latency p50 / p95 / p99 (live, ms)",
      "id": 10,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "refId": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "histogram_quantile(0.50, sum by (le, agent_id) (rate(ai_agent_latency_ms_bucket[30m])))\nor label_replace(histogram_quantile(0.50, sum by (le) (rate(ai_uc08_judge_latency_ms_bucket[30m]))), \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "legendFormat": "{{agent_id}} p50"
        },
        {
          "refId": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "histogram_quantile(0.95, sum by (le, agent_id) (rate(ai_agent_latency_ms_bucket[30m])))\nor label_replace(histogram_quantile(0.95, sum by (le) (rate(ai_uc08_judge_latency_ms_bucket[30m]))), \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "legendFormat": "{{agent_id}} p95"
        },
        {
          "refId": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "histogram_quantile(0.99, sum by (le, agent_id) (rate(ai_agent_latency_ms_bucket[30m])))\nor label_replace(histogram_quantile(0.99, sum by (le) (rate(ai_uc08_judge_latency_ms_bucket[30m]))), \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "legendFormat": "{{agent_id}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "auto",
            "spanNulls": true,
            "axisLabel": "latency (ms)"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "table",
      "title": "Turns by agent (all-time)",
      "id": 20,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "refId": "total",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum by (agent_id) (ai_agent_runs_total{status=~\"success|failed|refused\"}) or label_replace(sum(ai_uc08_create_sr_total) + on() (sum(ai_uc08_create_sr_failed_total) or vector(0)), \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "success",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum by (agent_id) (ai_agent_runs_total{status=\"success\"}) or label_replace(sum(ai_uc08_create_sr_total), \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "failed",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum by (agent_id) (ai_agent_runs_total{status=\"failed\"}) or label_replace(sum(ai_uc08_create_sr_failed_total) or vector(0), \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "rate",
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "expr": "sum by (agent_id) (ai_agent_runs_total{status=\"success\"}) / clamp_min(sum by (agent_id) (ai_agent_runs_total{status=~\"success|failed\"}), 1) or label_replace(  sum(ai_uc08_create_sr_total)   / clamp_min(sum(ai_uc08_create_sr_total) + (sum(ai_uc08_create_sr_failed_total) or vector(0)), 1),   \"agent_id\", \"uc08_fulfillment\", \"\", \"\")",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Success rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 0.9
                    },
                    {
                      "color": "green",
                      "value": 0.99
                    }
                  ]
                }
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Failures"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "right"
              },
              {
                "id": "noValue",
                "value": "0"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Successes"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total turns"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": [
          {
            "displayName": "Total",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "agent_id",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true
            },
            "indexByName": {
              "agent_id": 0,
              "Value #total": 1,
              "Value #success": 2,
              "Value #failed": 3,
              "Value #rate": 4
            },
            "renameByName": {
              "agent_id": "Agent",
              "Value #total": "Total turns",
              "Value #success": "Successes",
              "Value #failed": "Failures",
              "Value #rate": "Success rate"
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM cost per minute by tenant ($/min, live)",
      "id": 21,
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum by (tenant_id) (rate(ai_llm_cost_usd_micros_total[5m])) * 60 / 1e6",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cache hit / miss (live, per minute)",
      "id": 30,
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum(rate(ai_cache_hits_total[5m])) * 60",
          "legendFormat": "hits/min"
        },
        {
          "expr": "sum(rate(ai_cache_misses_total[5m])) * 60",
          "legendFormat": "misses/min"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache hit ratio (all-time)",
      "id": 31,
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum(ai_cache_hits_total) / clamp_min(sum(ai_cache_hits_total) + sum(ai_cache_misses_total), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "type": "stat",
      "title": "Tokens (cumulative)",
      "id": 32,
      "gridPos": {
        "x": 18,
        "y": 20,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum(ai_llm_tokens_total)"
        }
      ]
    },
    {
      "type": "row",
      "title": "LLM Cost & Usage \u2014 per model \u00d7 per tenant",
      "id": 39,
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Tokens by model (cumulative)",
      "id": 40,
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom"
          },
          "refId": "A",
          "expr": "sum by (model) (ai_llm_tokens_total)",
          "instant": true,
          "format": "table",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "sortBy": []
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "model": 0,
              "Value": 1
            },
            "renameByName": {
              "model": "Model",
              "Value": "Tokens"
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cost $/min by model (live)",
      "id": 41,
      "gridPos": {
        "x": 8,
        "y": 27,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(ai_llm_cost_usd_micros_total[5m])) * 60 / 1e6",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "type": "stat",
      "title": "Total LLM calls \u2014 by model (cumulative)",
      "id": 42,
      "gridPos": {
        "x": 16,
        "y": 27,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "round(sum by (model) (ai_llm_call_duration_ms_count))",
          "legendFormat": "{{model}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "type": "table",
      "title": "Per-tenant \u00d7 per-model breakdown (cumulative \u2014 finance/billing view)",
      "id": 43,
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom"
      },
      "targets": [
        {
          "expr": "sum by (tenant_id, model) (ai_llm_tokens_total)",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (tenant_id, model) (ai_llm_cost_usd_micros_total) / 1e6",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "sum by (tenant_id, model) (ai_llm_call_duration_ms_count)",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "deployment_environment": true,
              "exported_job": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_version": true,
              "fell_back": true,
              "telemetry_sdk_language": true,
              "telemetry_sdk_name": true,
              "telemetry_sdk_version": true
            },
            "renameByName": {
              "tenant_id": "Tenant",
              "model": "Model",
              "Value #A": "Total Tokens",
              "Value #B": "Cost ($)",
              "Value #C": "Total Calls"
            },
            "indexByName": {
              "Tenant": 0,
              "Model": 1,
              "Total Tokens": 2,
              "Cost ($)": 3,
              "Total Calls": 4
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost ($)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Calls"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 49,
      "type": "row",
      "title": "NATS Message Bus \u2014 live pub/sub on the wire",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Messages / sec (delivered, live)",
      "id": 50,
